{
  "screen_name": "spinner",
  "windowed_canvas": true,
  "cache_canvases": true,
  "menu_items": [
    {
      "id": "spinner",
      "animation_interval": 0.400,
      "animation": [
        { "image_path": "assets/spinner/spinner1.png","x": 140, "y": 40 },
        { "image_path": "assets/spinner/spinner2.png","x": 140, "y": 40 },
        { "image_path": "assets/spinner/spinner3.png","x": 140, "y": 40 },
        { "image_path": "assets/spinner/spinner4.png","x": 140, "y": 40 }
      ]
    }, {
      "id": "spinner_text",
      "unselectable": true,
      "layers": [
        { "variable_name": "$_INPUT", "use_template": "spinner_text" }
      ]
    }
  ],
  "text_area": {
    "x": 165, "y": 62, "w": 150, "h": 61,
    "font": "menu",
    "font_size": 12,
    "color": "warning_accent",
    "max_chars": 16,
    "max_lines": 4,
    "line_height": 14
  }
}
